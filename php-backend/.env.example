APP_NAME="PHP Auth API"
APP_ENV=local
APP_DEBUG=true
APP_BASE_URL="http://localhost:8000"

DB_DRIVER=sqlite
DB_SQLITE_PATH=database/app.db
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=auth_api
DB_USERNAME=root
DB_PASSWORD=

JWT_SECRET="replace_with_long_random_secret"
JWT_ISSUER="php-auth-api"
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800
